<?xml version="1.0" encoding="utf-8"?>
<!-- FileProvider paths required by share_plus and image_picker on Android 7+ -->
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Internal app files (PDFs, CSVs generated by reports) -->
    <files-path name="app_files" path="."/>
    <!-- App cache (temp files for sharing) -->
    <cache-path name="app_cache" path="."/>
    <!-- External cache (image_picker temp files) -->
    <external-cache-path name="external_cache" path="."/>
    <!-- External files (downloads) -->
    <external-files-path name="external_files" path="."/>
    <!-- Required by image_picker for camera captures -->
    <external-path name="external_storage" path="."/>
</paths>
