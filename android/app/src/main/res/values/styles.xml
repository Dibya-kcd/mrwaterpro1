<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Launch theme — shown while Flutter engine is loading.
         Using a solid dark background prevents the white flash on startup
         before the splash video begins. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <!-- Edge-to-edge: status bar and nav bar are transparent -->
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>

    <!-- Normal theme — applied after Flutter engine is ready.
         NormalTheme is set in MainActivity after the splash. -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>
